<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title || 'Facultative System' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f5f7fb;
      color: #1f2937;
    }

    .site-header {
      background: #111827;
      color: white;
      padding: 16px 24px;
    }

    .site-header__inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .brand {
      font-size: 20px;
      font-weight: bold;
    }

    .nav {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      align-items: center;
    }

    .nav a {
      color: white;
      text-decoration: none;
    }

    .nav a:hover {
      text-decoration: underline;
    }

    .container {
      max-width: 1100px;
      margin: 32px auto;
      padding: 0 20px;
    }

    .card {
      background: white;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      margin-bottom: 20px;
    }

    .card--narrow {
      max-width: 500px;
      margin: 0 auto;
    }

    .grid {
      display: grid;
      gap: 16px;
    }

    .grid--courses {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }

    .muted {
      color: #6b7280;
    }

    .error {
      background: #fee2e2;
      color: #991b1b;
      padding: 12px 14px;
      border-radius: 8px;
      margin-bottom: 16px;
    }

    .success {
      color: #166534;
    }

    .badge {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: #e5e7eb;
      font-size: 14px;
      margin-top: 8px;
    }

    .badge--completed {
      background: #dcfce7;
      color: #166534;
    }

    .badge--progress {
      background: #dbeafe;
      color: #1d4ed8;
    }

    .badge--enrolled {
      background: #f3f4f6;
      color: #374151;
    }

    .button,
    button {
      background: #111827;
      color: white;
      border: none;
      border-radius: 8px;
      padding: 10px 14px;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      font-size: 14px;
    }

    .button:hover,
    button:hover {
      opacity: 0.92;
    }

    input,
    textarea,
    select {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      font-size: 14px;
    }

    label {
      display: inline-block;
      margin-bottom: 6px;
      font-weight: bold;
    }

    .field {
      margin-bottom: 14px;
    }

    .list {
      padding-left: 18px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      overflow: hidden;
      border-radius: 12px;
    }

    th,
    td {
      border: 1px solid #e5e7eb;
      padding: 12px;
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #f9fafb;
    }

    .top-actions {
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="site-header__inner">
      <div class="brand">Facultative System</div>

      <nav class="nav">
        <% if (user) { %>
          <a href="/dashboard">Dashboard</a>

          <% if (user.role === 'student') { %>
            <a href="/courses">All courses</a>
            <a href="/my-courses">My courses</a>
          <% } %>

          <% if (user.role === 'teacher') { %>
            <a href="/teacher/courses">My teaching courses</a>
          <% } %>

          <% if (user.role === 'admin') { %>
            <a href="/admin/users">Users</a>
            <a href="/admin/users/create">Create user</a>
            <a href="/admin/courses">Courses</a>
          <% } %>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register">Register</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="container">